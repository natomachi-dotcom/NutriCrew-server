PORT=3000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority
# Long random string. Required header (x-admin-key) to access /api/users,
# /api/subscribers and /api/meals/*.
ADMIN_API_KEY=replace-with-a-long-random-string
# Long random string shared with nutricrew-backend. Required header
# (x-internal-key) on /api/pairing-usage/* — must match nutricrew-backend's
# INTERNAL_API_KEY exactly.
INTERNAL_API_KEY=replace-with-a-long-random-string-shared-with-nutricrew-backend
